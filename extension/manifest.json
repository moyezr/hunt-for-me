{
  "manifest_version": 3,
  "name": "Hunt For Me",
  "version": "0.1.0",
  "description": "Detects job application fields and fills AI-generated answers after review.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.naukri.com/*",
    "https://*.indeed.com/*",
    "https://*.wellfound.com/*",
    "https://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Hunt For Me"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naukri.com/*",
        "https://*.indeed.com/*",
        "https://*.wellfound.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
